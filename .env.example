# Local persistence.
MOVIE_NIGHT_MEDIATOR_SQLITE_PATH=./data/movie_night_mediator.sqlite3

# Hosted persistence. When set without a SQLite override, PostgreSQL is used.
DATABASE_URL=

# Local web-to-API routing.
API_BASE_URL=http://127.0.0.1:8000

# Hosted household access. Leave unset for local development.
HOUSEHOLD_ACCESS_PASSWORD=
HOUSEHOLD_SESSION_SECRET=
BACKEND_SERVICE_TOKEN=

# Optional live TMDb candidate mode.
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=

# Optional web proxy overrides.
MOVIE_NIGHT_RECOMMENDATION_SOURCE=
MOVIE_NIGHT_SCORING_ENGINE=
MOVIE_NIGHT_COLLABORATIVE_MODEL_PATH=
MOVIE_NIGHT_HYBRID_MODEL_PATH=
MOVIE_NIGHT_LEARNED_TASTE_LINKS_PATH=
API_REQUEST_TIMEOUT_MS=

# Deferred or legacy integrations.
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
