{
  "name": "movie-night-mediator",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.6.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "hosted:preflight": "node scripts/hosted_android_preflight.mjs && node --check apps/web/public/sw.js && node scripts/run_api_uv.mjs run python -m py_compile ../../scripts/migrate_sqlite_to_postgres.py",
    "hosted:migrate": "node scripts/run_api_uv.mjs run python ../../scripts/migrate_sqlite_to_postgres.py",
    "hosted:check": "pnpm hosted:preflight && pnpm check && pnpm build:web",
    "beta:preflight": "node scripts/beta_readiness_preflight.mjs",
    "beta:check": "pnpm beta:preflight && pnpm check",
    "beta:mvp4": "node scripts/mvp_plus_4_acceptance_gate.mjs",
    "beta:mvp5": "node scripts/mvp_plus_5_acceptance_gate.mjs",
    "beta:dogfood": "MOBILE_UX_SMOKE_EXPECT_API=1 pnpm smoke:ux:mobile",
    "beta:dogfood:live": "MOVIE_NIGHT_RECOMMENDATION_SOURCE=live_tmdb MOBILE_UX_SMOKE_EXPECT_API=1 MOBILE_UX_SMOKE_EXPECT_RECOMMENDATION_SOURCE=live_tmdb pnpm smoke:ux:mobile",
    "eval:mvp4": "python3 scripts/mvp_plus_4_evaluation.py",
    "eval:mvp5": "python3 scripts/mvp_plus_5_evaluation.py",
    "eval:scoring-v2:v1": "python3 scripts/scoring_v2_v1_baseline.py",
    "eval:scoring-v2:compare": "python3 scripts/scoring_v2_comparison.py",
    "eval:movielens:census": "python3 scripts/movielens_32m_census.py",
    "eval:movielens:protocol": "python3 scripts/movielens_protocol_manifests.py",
    "eval:movielens:protocol:verify": "python3 scripts/movielens_protocol_manifests.py --verify",
    "eval:movielens:trace": "python3 scripts/movielens_one_user_tracer.py",
    "eval:movielens:baselines": "python3 scripts/movielens_cohort_baselines.py",
    "eval:movielens:depth-curve": "python3 scripts/movielens_profile_depth_curve.py",
    "eval:movielens:collaborative": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_collaborative_baseline.py",
    "eval:movielens:collaborative:verify": "node scripts/run_api_uv.mjs run python ../../scripts/verify_collaborative_artifact.py",
    "eval:movielens:content-snapshot": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_content_snapshot.py",
    "eval:movielens:hybrid": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_hybrid_baseline.py",
    "eval:movielens:hybrid:verify": "node scripts/run_api_uv.mjs run python ../../scripts/verify_hybrid_artifact.py",
    "model:prepare:movielens-links": "python3 scripts/prepare_movielens_runtime_links.py",
    "eval:household-models": "node scripts/run_api_uv.mjs run python ../../scripts/run_household_model_comparison.py",
    "eval:movielens:development-protocol": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_model_improvement_manifests.py",
    "eval:movielens:development-protocol:verify": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_model_improvement_manifests.py --verify",
    "eval:movielens:support-aware": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_support_aware_hybrid.py",
    "eval:movielens:support-aware:verify": "node scripts/run_api_uv.mjs run python ../../scripts/verify_support_aware_artifact.py",
    "eval:movielens:collaborative-search": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_collaborative_search.py",
    "eval:movielens:collaborative-search:verify": "node scripts/run_api_uv.mjs run python ../../scripts/verify_collaborative_search_artifact.py",
    "eval:movielens:internal-winner": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_internal_winner.py",
    "eval:movielens:replacement-protocol": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_replacement_sealed_protocol.py",
    "eval:movielens:replacement-protocol:verify": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_replacement_sealed_protocol.py --verify",
    "eval:movielens:replacement-sealed": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_replacement_sealed_benchmark.py",
    "eval:movielens:ablate": "node scripts/run_api_uv.mjs run python ../../scripts/movielens_feature_ablation.py",
    "eval:movielens:select": "node scripts/run_api_uv.mjs run python ../../scripts/finalize_movielens_model_selection.py",
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build",
    "smoke:ux:mobile": "node scripts/mobile_pass_the_phone_ux_smoke.mjs",
    "test:api": "node scripts/run_api_uv.mjs run python -m unittest discover -s tests",
    "test:tooling": "node --test scripts/tests/*.test.mjs",
    "test:web:state": "node --experimental-strip-types --test apps/web/tests/*.test.mjs",
    "compile:api": "node scripts/run_api_uv.mjs run python -m compileall -q src tests",
    "check": "pnpm test:tooling && pnpm test:api && pnpm compile:api && pnpm test:web:state"
  }
}
